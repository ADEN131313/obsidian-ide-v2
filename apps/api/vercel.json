{
  "version": 2,
  "builds": [
    {
      "src": "apps/api/src/index.ts",
      "use": "@vercel/node"
    }
  ],
  "buildCommand": "npx -y pnpm@9.15.0 --filter @obsidian/api build",
  "outputDirectory": "dist",
  "installCommand": "npx -y pnpm@9.15.0 install --frozen-lockfile",
  "routes": [
    {
      "src": "/api/(.*)",
      "dest": "apps/api/src/index.ts"
    }
  ],
  "env": {
    "NODE_ENV": "production"
  }
}
