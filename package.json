{
  "name": "@obsidian/root",
  "version": "1.0.0",
  "description": "Production-grade OBSIDIAN IDE with advanced AI and professional tooling",
  "license": "MIT",
  "private": true,
  "type": "module",
  "engines": {
    "node": ">=20.0.0",
    "pnpm": ">=9.0.0"
  },
  "packageManager": "pnpm@9.15.0",
  "scripts": {
    "build": "turbo run build",
    "dev": "turbo run dev --parallel",
    "typecheck": "turbo run typecheck",
    "test": "turbo run test",
    "test:e2e": "pnpm --filter '@obsidian/web' run test:e2e",
    "lint": "biome check .",
    "lint:fix": "biome check . --write",
    "format": "biome format . --write",
    "db:generate": "pnpm --filter '@obsidian/db' run db:generate",
    "db:migrate": "pnpm --filter '@obsidian/db' run db:migrate",
    "db:studio": "pnpm --filter '@obsidian/db' run db:studio",
    "docker:up": "docker-compose -f infra/docker/docker-compose.yml up -d",
    "docker:down": "docker-compose -f infra/docker/docker-compose.yml down"
  },
  "devDependencies": {
    "@biomejs/biome": "^1.9.4",
    "turbo": "^2.3.3",
    "typescript": "~5.9.2"
  }
}
