# Database (PostgreSQL required - use Vercel Postgres, Neon, or Railway)
DATABASE_URL=postgresql://user:password@host:5432/obsidian

# JWT (generate a strong secret for production)
JWT_SECRET=your-super-secret-jwt-key-minimum-32-characters

# OpenAI (required for AI assistant features)
OPENAI_API_KEY=sk-your-openai-api-key

# Frontend API URL (update after API deployment)
VITE_API_URL=https://your-api.vercel.app

# Optional: Error tracking
# SENTRY_DSN=your-sentry-dsn